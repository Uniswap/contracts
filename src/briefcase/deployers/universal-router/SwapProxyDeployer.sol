pragma solidity >=0.8.4;

/// @title SwapProxyDeployer
/// @notice Deploys the canonical SwapProxy to the same deterministic address on every chain.
/// @dev FROZEN canonical artifact. Do NOT regenerate this initcode via `./script/util/create_briefcase.sh`
///      (this deployer intentionally omits the autogenerated source-contract marker so the script skips it).
///
///      The canonical address `0x0000000085E102724e78eCd2F45DC9cA239Affad` is fixed by
///      {CREATE2 factory 0x4e59...4956C, SALT, INITCODE}. The initcode below is the frozen,
///      mainnet-verified SwapProxy build (solc 0.8.26, optimizer_runs=4444, via-IR, evm=cancun,
///      bytecode_hash=ipfs; 1005-byte runtime). It is deliberately NOT the build the repo's
///      `universal-router` foundry profile (optimizer_runs=1, bytecode_hash=none) would produce:
///      recompiling from submodule source would change the bytecode and therefore the address.
///      SwapProxy only references the IUniversalRouter interface, so UR router upgrades never change
///      this address.
///
///      Legacy pre-CREATE2 instances live at 0x02E5be68d46DAc0b524905BfF209cf47EE6dB2A9 (plain CREATE
///      at nonce 0 of deployer 0xb259f71F8Fa2B0165c4d71061C4bf6c77444aC87); they are immutable and
///      ownerless, so they remain on-chain and consumers migrate to the CREATE2 address above.
library SwapProxyDeployer {
    /// @notice Arachnid deterministic deployment proxy; identical on every supported chain.
    address internal constant CREATE2_FACTORY = 0x4e59b44847b379578588920cA78FbF26c0B4956C;
    /// @notice Vanity-mined salt for the 4-leading-zero-byte canonical address (Permit2/CaliburEntry convention).
    bytes32 internal constant SALT = 0xd00319ff7795e528cc1ccd28bd6e08e46a42130d69ab4992d656773ba5fb323c;
    /// @notice keccak256 of the frozen initcode; guards against artifact drift.
    bytes32 internal constant INITCODE_HASH = 0x342d83f4d7400dd603e2a6829db9cb032e7f62a2dda94746f2acd4e7e881bb2f;
    /// @notice Deterministic SwapProxy address for {CREATE2_FACTORY, SALT, INITCODE_HASH}.
    address internal constant CANONICAL_ADDRESS = 0x0000000085E102724e78eCd2F45DC9cA239Affad;

    error InitcodeHashMismatch(bytes32 expected, bytes32 actual);
    error AddressMismatch(address expected, address actual);
    error FactoryMissing(address factory);
    error DeployFailed();

    /// @notice Deploys the canonical SwapProxy via the deterministic factory. Idempotent: returns the
    ///         existing instance if SwapProxy already lives at the canonical address on this chain.
    /// @return swapProxy The canonical SwapProxy address.
    function deploy() internal returns (address swapProxy) {
        bytes memory initcode_ = initcode();
        bytes32 initcodeHash = keccak256(initcode_);
        if (initcodeHash != INITCODE_HASH) revert InitcodeHashMismatch(INITCODE_HASH, initcodeHash);

        address predicted =
            address(uint160(uint256(keccak256(abi.encodePacked(bytes1(0xff), CREATE2_FACTORY, SALT, initcodeHash)))));
        if (predicted != CANONICAL_ADDRESS) revert AddressMismatch(CANONICAL_ADDRESS, predicted);

        // Idempotent: if SwapProxy is already at the canonical address on this chain, do nothing.
        if (CANONICAL_ADDRESS.code.length != 0) return CANONICAL_ADDRESS;
        if (CREATE2_FACTORY.code.length == 0) revert FactoryMissing(CREATE2_FACTORY);

        // Arachnid factory calldata is `salt (32 bytes) ++ initcode`.
        (bool ok,) = CREATE2_FACTORY.call(abi.encodePacked(SALT, initcode_));
        if (!ok || CANONICAL_ADDRESS.code.length == 0) revert DeployFailed();
        return CANONICAL_ADDRESS;
    }

    /// @notice Frozen canonical SwapProxy creation bytecode (no constructor args).
    /// @dev NOT autogenerated. See the library NatSpec: must not be overwritten by create_briefcase.sh.
    function initcode() internal pure returns (bytes memory) {
        return hex'';
    }
}
